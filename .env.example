# =============================================================================
# MRB Learning Platform — Production environment template (VPS / PM2 + Nginx)
# =============================================================================
#
# Copy to server/.env and fill in secrets. NEVER commit server/.env.
#
#   cp .env.example server/.env
#   nano server/.env
#
# Frontend build-time vars (VITE_*) are read from this file during ./deploy.sh
# or can live in client/.env for local development only.
#
# See docs/deployment/README.md for full setup guide.
# =============================================================================

# --- Core ---
NODE_ENV=production
PORT=4000
CLIENT_URL=https://your-domain.example
# Comma-separated extra browser origins (optional)
# TRUSTED_ORIGINS=

# --- Reverse proxy (required in production behind Nginx) ---
TRUST_PROXY=1
LISTEN_HOST=127.0.0.1

# --- MySQL ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=mrb_app
MYSQL_PASSWORD=change_me_strong_password
MYSQL_DATABASE=mrb_learning
# MYSQL_POOL_CONNECTION_LIMIT=30

# --- Redis (required in production) ---
REDIS_URL=redis://127.0.0.1:6379
REQUIRE_REDIS_IN_PRODUCTION=true

# --- JWT & session security (>= 32 chars each; generate with openssl rand -base64 48) ---
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ISSUER=mrb-learning
JWT_AUDIENCE=mrb-learning-clients
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=90d
ALLOW_LEGACY_TOKEN_VERSION=false

# --- Admin secret path (>= 16 URL-safe chars; must match frontend build) ---
# Generate: node -e "console.log(require('crypto').randomBytes(18).toString('base64url'))"
ADMIN_SECRET_PATH=
ALLOW_ADMIN_BOOTSTRAP=false

# --- Teacher Q&A thread HMAC (>= 32 chars) ---
TEACHER_THREAD_SECRET=

# --- Cookie security (HTTPS required) ---
REFRESH_COOKIE_SECURE=true
ACCESS_COOKIE_SECURE=true
REFRESH_COOKIE_SAMESITE=lax
ACCESS_COOKIE_SAMESITE=lax
REFRESH_COOKIE_PATH=/api/auth
CSRF_COOKIE_PATH=/
ACCESS_COOKIE_PATH=/api
ATTEMPT_TOKEN_MODE=cookie
ATTEMPT_COOKIE_SECURE=true

# --- Google OAuth (same value on server + Vite build) ---
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=

# --- Email ---
EMAIL_PROVIDER=sendgrid
EMAIL_FROM=noreply@your-domain.example
SENDGRID_API_KEY=
EMAIL_SANDBOX_MODE=false
# EMAIL_WEBHOOK_SECRET=
# EMAIL_WEBHOOK_SIGNATURE_SECRET=

# --- Safepay payments ---
SAFEPAY_ENV=production
SAFEPAY_MERCHANT_SECRET=
SAFEPAY_MERCHANT_API_KEY=
SAFEPAY_WEBHOOK_SECRET=

# --- Observability (optional) ---
# METRICS_SCRAPER_TOKEN=
# OBSERVABILITY_INTERNAL_CIDRS=127.0.0.1,::1

# --- PM2 graceful shutdown ---
SHUTDOWN_TIMEOUT_MS=15000

# --- Health checks (used by deploy.sh; defaults hit loopback API) ---
# HEALTH_CHECK_URL=http://127.0.0.1:4000/api/health
# READY_CHECK_URL=http://127.0.0.1:4000/api/ready

# --- Development-only overrides (do NOT use on VPS) ---
# NODE_ENV=development
# REFRESH_COOKIE_SECURE=false
# ACCESS_COOKIE_SECURE=false
# TRUST_PROXY=false

# Full reference for all tunables: server/.env.example
