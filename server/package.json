{
  "name": "mrb-learning-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MRB Learning Platform backend API",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:docker": "docker compose -f ../docker-compose.yml up -d mysql",
    "db:docker:logs": "docker compose -f ../docker-compose.yml logs -f mysql",
    "db:bootstrap": "node scripts/bootstrap-db-user.mjs",
    "cleanup:auth-sessions": "node scripts/cleanup-revoked-auth-sessions.js",
    "cleanup:email-verifications": "node scripts/cleanup-email-verifications.js",
    "cleanup:stale-unverified-users": "node scripts/cleanup-stale-unverified-users.js",
    "simulate:abuse": "node scripts/simulate-distributed-abuse.mjs",
    "test:auth": "node scripts/verify-auth-flow.mjs",
    "test:course-write": "node scripts/verify-course-write-layer.mjs",
    "test:course-dto": "node scripts/verify-course-dto-shape.mjs",
    "test:course-paths": "node scripts/verify-course-api-paths.mjs",
    "test:course-contract": "node scripts/verify-course-contract-grep.mjs",
    "test:course-pricing": "node scripts/verify-course-pricing-contract.mjs",
    "test:subjects-foundation": "node scripts/verify-subjects-foundation.mjs",
    "test:course-batches-shape": "node scripts/verify-course-batches-shape.mjs",
    "test:course-batches-security": "node scripts/verify-course-batches-security.mjs",
    "test:course-batches-routes": "node scripts/verify-course-batches-routes.mjs",
    "test:course-batches-all": "node scripts/verify-course-batches-shape.mjs && node scripts/verify-course-batches-security.mjs && node scripts/verify-course-batches-routes.mjs",
    "test:course-wizard-flow": "node scripts/verify-course-wizard-flow.mjs",
    "test:course-batch-duplicates": "node scripts/verify-course-batch-duplicates.mjs",
    "test:course-all": "node scripts/verify-course-dto-shape.mjs && node scripts/verify-course-write-layer.mjs && node scripts/verify-course-api-paths.mjs && node scripts/verify-course-contract-grep.mjs && node scripts/verify-course-pricing-contract.mjs && node scripts/verify-course-wizard-flow.mjs && node scripts/verify-course-batch-duplicates.mjs",
    "test:question-list": "node scripts/verify-question-list-api.mjs",
    "test:question-update": "node scripts/verify-question-update-api.mjs",
    "test:question-phase1-mcq": "node scripts/verify-question-phase1-mcq.mjs",
    "test:question-bank-rate-limit": "node scripts/verify-question-bank-rate-limit.mjs",
    "test:question-difficulty": "node scripts/verify-question-difficulty.mjs",
    "test:question-field-limits": "node scripts/verify-question-field-limits.mjs",
    "test:question-content-security": "node scripts/verify-question-content-security.mjs",
    "test:question-correct-answer": "node scripts/verify-question-correct-answer.mjs",
    "test:question-bank-integrity": "node scripts/verify-question-bank-integrity.mjs",
    "audit:question-bank-integrity": "node scripts/audit-question-bank-integrity.mjs",
    "test:question-bank-active-filter": "node scripts/verify-question-bank-active-filter.mjs",
    "migrate:question-bank-soft-delete": "node scripts/run-question-bank-soft-delete-migration.mjs",
    "audit:scoped-queries": "node scripts/audit-scoped-query-migration.mjs",
    "test:secure-attempt": "node scripts/verify-secure-attempt-context.mjs",
    "test:attempt-composition": "node scripts/verify-test-attempt-composition.mjs",
    "test:lifecycle-lockdown": "node scripts/verify-test-lifecycle-lockdown.mjs",
    "test:subject-enforcement": "node scripts/verify-test-subject-enforcement.mjs",
    "audit:test-subjects": "node scripts/audit-test-subject-integrity.mjs",
    "test:validation-core": "node scripts/verify-test-validation-core.mjs",
    "test:publish-gate": "node scripts/verify-test-publish-gate.mjs",
    "test:composition-model": "node scripts/verify-test-composition-model.mjs",
    "audit:test-subject-legacy": "node scripts/audit-test-subject-legacy.mjs",
    "audit:test-enum-values": "node scripts/audit-test-enum-values.mjs",
    "test:enum-enforcement": "node scripts/verify-test-enum-enforcement.mjs",
    "test:security-audit": "node scripts/verify-test-security-audit.mjs",
    "test:protection-grid": "node scripts/verify-protection-grid.mjs",
    "test:db-boundary": "node scripts/verify-db-entitlement-boundary.mjs",
    "test:enrollment-lifecycle": "node scripts/verify-enrollment-lifecycle.mjs",
    "test:course-ownership": "node scripts/verify-course-ownership.mjs && node src/services/courseOwnership.service.test.examples.mjs",
    "test:student-test-listing": "node scripts/verify-student-test-listing.mjs && node src/services/testOwnership.service.test.examples.mjs && node src/services/studentTestListingStatus.test.examples.mjs",
    "test:student-test-start": "node scripts/verify-student-test-start.mjs && node src/services/studentTestStart.service.test.examples.mjs",
    "test:student-answer-save": "node scripts/verify-student-answer-save.mjs && node src/services/studentAnswerSave.service.test.examples.mjs",
    "test:public-test-attempt": "node scripts/verify-public-test-attempt.mjs && node src/services/testAttempt.service.test.examples.mjs",
    "test:attempt-timing": "node scripts/verify-attempt-timing.mjs && node src/services/attemptTiming.service.test.examples.mjs && node src/services/attemptTimerValidation.service.test.examples.mjs && node src/services/attemptExpiry.service.test.examples.mjs",
    "repair:attempt-expiry": "node scripts/repair-invalid-attempt-expiry.mjs",
    "security:audit": "npm audit --omit=dev",
    "chaos:matrix": "node -e \"console.log('See server/docs/chaos-test-matrix.md')\""
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "@sfpy/node-core": "^0.3.5",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.76.6",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.22.3",
    "nanoid": "^5.0.8",
    "nodemailer": "^8.0.7",
    "redis": "^4.7.1",
    "sanitize-html": "^2.17.3",
    "sharp": "^0.34.5",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
