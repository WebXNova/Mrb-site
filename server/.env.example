NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173
# Comma-separated extra browser origins (CORS + Origin checks). CLIENT_URL is always included.
# TRUSTED_ORIGINS=https://app.example.com,https://admin.example.com
# How long to keep revoked auth_sessions rows before hard-delete (cleanup script / cron)
# AUTH_SESSION_RETENTION_DAYS=30

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=your_mysql_database
REDIS_URL=redis://127.0.0.1:6379

# Must be cryptographically strong (>= 32 chars)
JWT_ACCESS_SECRET=your_strong_random_access_secret
JWT_REFRESH_SECRET=your_strong_random_refresh_secret
JWT_ISSUER=mrb-learning
JWT_AUDIENCE=mrb-learning-clients
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
REQUIRE_REDIS_IN_PRODUCTION=true
# Must be false in production so access tokens always carry token_version and sid.
ALLOW_LEGACY_TOKEN_VERSION=false

# Optional: integration checks for npm run test:auth
# TEST_ADMIN_EMAIL=admin@example.com
# TEST_ADMIN_PASSWORD=your_password

# Required for admin bootstrap script
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=secure.admin
ADMIN_PASSWORD=a_strong_admin_password_at_least_12_chars

# Keep false unless intentionally bootstrapping in production
ALLOW_ADMIN_BOOTSTRAP=false
