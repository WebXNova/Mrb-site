NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173
# Comma-separated extra browser origins (CORS + Origin checks). CLIENT_URL is always included.
# TRUSTED_ORIGINS=https://app.example.com,https://admin.example.com
# How long to keep revoked auth_sessions rows before hard-delete (cleanup script / cron)
# AUTH_SESSION_RETENTION_DAYS=30

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
# Use quotes if the password contains @ ? # space or other special characters:
# MYSQL_PASSWORD="your@complex?password"
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=your_mysql_database
REDIS_URL=redis://127.0.0.1:6379

# Must be cryptographically strong (>= 32 chars)
JWT_ACCESS_SECRET=your_strong_random_access_secret
JWT_REFRESH_SECRET=your_strong_random_refresh_secret
# Optional comma-separated previous keys during key rotation windows.
# JWT_ACCESS_PREVIOUS_SECRETS=old_access_secret_1,old_access_secret_2
# JWT_REFRESH_PREVIOUS_SECRETS=old_refresh_secret_1,old_refresh_secret_2
JWT_ISSUER=mrb-learning
JWT_AUDIENCE=mrb-learning-clients
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
REQUIRE_REDIS_IN_PRODUCTION=true
# Must be false in production so access tokens always carry token_version and sid.
ALLOW_LEGACY_TOKEN_VERSION=false
# Cookie defaults for refresh token. Use SAMESITE=none + SECURE=true for cross-site HTTPS deployments.
REFRESH_COOKIE_SAMESITE=lax
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_PATH=/api/auth
# CSRF double-submit cookie must use path `/` so SPA pages can read it; refresh tokens stay on REFRESH_COOKIE_PATH.
CSRF_COOKIE_PATH=/
ACCESS_COOKIE_SAMESITE=lax
ACCESS_COOKIE_SECURE=false
ACCESS_COOKIE_PATH=/api
ACCESS_COOKIE_MAX_AGE_MS=900000
# Production baseline:
# NODE_ENV=production
# REFRESH_COOKIE_SECURE=true
# ACCESS_COOKIE_SECURE=true
# Set true or proxy hop count behind load balancers, e.g. 1
TRUST_PROXY=false
# Optional anti-automation challenge shared key for suspicious signup bursts.
# AUTH_CHALLENGE_KEY=change_this_to_long_random_value

# Abuse & verification (rate limits have safe defaults). Set BLOCKED_EMAIL_DOMAINS=comma,separated,to,block signup.
# REQUIRE_REDIS_FOR_CRITICAL_AUTH_WRITES=true
# Turnstile (optional; used after abuse thresholds): https://developers.cloudflare.com/turnstile/
# TURNSTILE_SECRET_KEY=
# Alias: ABUSE_CAPTCHA_SECRET=
# Fine-grained limits override with VERIFICATION_* (see env.js).

# Optional: integration checks for npm run test:auth
# TEST_ADMIN_EMAIL=admin@example.com
# TEST_ADMIN_PASSWORD=your_password

# Required for admin bootstrap script
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=secure.admin
ADMIN_PASSWORD=a_strong_admin_password_at_least_12_chars

# Keep false unless intentionally bootstrapping in production
ALLOW_ADMIN_BOOTSTRAP=false

# Email provider contract
# EMAIL_PROVIDER=smtp (default) or sendgrid
EMAIL_PROVIDER=sendgrid
# Plain address or "Display Name <addr@domain>". Trimmed/quotes stripped (Windows .env safe).
EMAIL_FROM=verified-sender@yourdomain.com
SENDGRID_API_KEY=your_sendgrid_api_key
# Use SendGrid sandbox in non-production smoke tests
EMAIL_SANDBOX_MODE=false

# SMTP fallback (optional when EMAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your_sendgrid_api_key
# SMTP_FROM=verified-sender@yourdomain.com

# Safepay — keys MUST match SAFEPAY_ENV (sandbox dashboard → SAFEPAY_ENV=sandbox → https://sandbox.api.getsafepay.com ; live → production → https://api.getsafepay.com ).
# SAFEPAY_ENV=sandbox
#
# SECRET → @sfpy/node-core constructor ONLY (header x-sfpy-merchant-secret). Never frontend.
#   SAFEPAY_MERCHANT_SECRET=paste_here
#   # alt: SAFEPAY_SECRET_KEY=  | legacy: SAFEPAY_API_KEY (same semantic = merchant SECRET — NOT publishable key)
#
# Publishable → payments.session.setup { merchant_api_key } ONLY — never SDK ctor.
#   SAFEPAY_MERCHANT_API_KEY=paste_here   # alias: SAFEPAY_PUBLIC_KEY=
#
# Webhook signing: 64-character hexadecimal secret (32 bytes) — HMAC-SHA512 over `${X-SFPY-TIMESTAMP}.${rawBodyUtf8}`. Decode with Buffer.from(secret, 'hex') only (not base64). Forward X-SFPY-TIMESTAMP and X-SFPY-SIGNATURE from Safepay unchanged.
# SAFEPAY_WEBHOOK_SECRET=
#
# Replay protection window for X-SFPY-TIMESTAMP (reject older signed copies). Seconds; default 300.
# SAFEPAY_WEBHOOK_TIMESTAMP_SKEW_SECONDS=300
# Max webhook JSON payload size that express.raw accepts (bytes). Default 524288 (512KiB).
# SAFEPAY_WEBHOOK_MAX_BYTES=524288
# Redis TTL (seconds) for duplicate-delivery cache after successful processing. Default 86400.
# SAFEPAY_WEBHOOK_REPLAY_TTL_SECONDS=86400
# Sliding limit per IP per minute for POST /api/payments/webhook. Default 240.
# SAFEPAY_WEBHOOK_PER_IP_PER_MINUTE=240
# SAFEPAY_DEBUG=false
# Log webhook ingress summaries (still no secrets / raw payloads). Mostly for staging.
# SAFEPAY_WEBHOOK_REQUEST_LOG=false
# Temporary deep crash / signature debug (logs full headers & secret length; disable after triage).
# SAFEPAY_WEBHOOK_CRASH_DEBUG=false
# Temporary: log webhook headers / body hash / partial secret (disable after triage).
# SAFEPAY_WEBHOOK_DIAGNOSTIC=false
