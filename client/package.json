    "test:quiz-draft-server-save": "node src/features/quiz-builder/persistence/quizDraftServerSave.test.examples.mjs",
    "test:quiz-draft-conflict": "node src/features/quiz-builder/persistence/quizDraftConflict.test.examples.mjs",
    "test:quiz-draft-recovery": "node src/features/quiz-builder/persistence/quizDraftRecovery.test.examples.mjs",
    "test:quiz-mcq-client-validation": "node src/features/quiz-builder/validation/quizMcqClientValidation.test.examples.mjs",
