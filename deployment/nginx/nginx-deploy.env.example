# MRB Learning Platform — Nginx deployment configuration
#
# Copy to nginx-deploy.env, fill in your values, then run:
#   sudo bash deployment/scripts/setup-nginx.sh
#
#   cp deployment/nginx/nginx-deploy.env.example deployment/nginx/nginx-deploy.env
#   nano deployment/nginx/nginx-deploy.env
#   sudo bash deployment/scripts/setup-nginx.sh

# Your production domain (required)
# Example: DOMAIN=learning.example.com
DOMAIN=

# Absolute path to the repository root on the VPS (required)
# Example: APP_ROOT=/var/www/mrb-learning
APP_ROOT=
